# MUMU MINI BOT - WhatsApp Bot Configuration
# Copy this file to .env and fill in your credentials

# Bot Credentials
OWNER_ID=263776719736
OWNER_NUMBER=263776719736
PREFIX=/

# WhatsApp Configuration
WHATSAPP_SESSION_NAME=MUMU_BOT

# Deployment Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Render Deployment
RENDER_SERVICE_ID=your_render_service_id
PAIRING_CODE_ENABLED=true
PAIRING_CODE_LINK=https://render.com

# API Keys
OPENAI_API_KEY=your_openai_key_here
WEATHERAPI_KEY=your_weather_api_key
YOUTUBE_API_KEY=your_youtube_api_key
GOOGLE_TRANSLATE_API_KEY=your_google_translate_key

# Database Configuration
DATABASE_URL=sqlite:./database/mumu.db
REDIS_URL=redis://localhost:6379

# Webhook Configuration
WEBHOOK_URL=https://your-webhook-url.com
WEBHOOK_SECRET=your_webhook_secret

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/mumu.log

# Features Toggle
ENABLE_AI_CHAT=true
ENABLE_AUTO_REPLY=true
ENABLE_MEDIA_DOWNLOAD=true
ENABLE_GROUP_MANAGEMENT=true
ENABLE_USER_STATS=true
